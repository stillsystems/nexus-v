{
  "name": "nexus-v-vscode",
  "displayName": "Nexus-V for VS Code",
  "publisher": "stillsystems",
  "description": "Official VS Code extension for the Nexus-V scaffolding engine.",
  "version": "0.0.1",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nexus-v.createProject",
        "title": "Nexus-V: New Project",
        "category": "Still Systems"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "echo \"No tests yet\""
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.0.0"
  }
}
