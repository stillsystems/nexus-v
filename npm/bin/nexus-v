#!/usr/bin/env node

const { spawnSync } = require('child_process');
const os = require('os');
const path = require('path');
const fs = require('fs');

/**
 * Nexus-V NPM Wrapper
 * This script acts as a bridge between Node/NPX and the native Go binary.
 */

function getBinaryName() {
    const platform = os.platform();
    return platform === 'win32' ? 'nexus-v.exe' : 'nexus-v';
}

function main() {
    const platform = os.platform();
    const binaryName = getBinaryName();
    
    // 1. Look for a bundled binary in the same directory
    let binaryPath = path.join(__dirname, binaryName);

    // 2. Fallback to system-wide 'nexus-v' if bundled version is missing
    if (!fs.existsSync(binaryPath)) {
        binaryPath = binaryName;
    }

    const args = process.argv.slice(2);
    
    // Execute the binary and pipe all I/O
    const result = spawnSync(binaryPath, args, { 
        stdio: 'inherit', 
        shell: platform === 'win32' 
    });

    if (result.error) {
        if (result.error.code === 'ENOENT') {
            console.error(`\x1b[31m[nexus-v] Error: Native binary not found.\x1b[0m`);
            console.error(`Please install the native binary for your platform or ensure it is in your PATH.`);
            console.error(`Visit https://github.com/stillsystems/nexus-v for installation instructions.`);
        } else {
            console.error(`\x1b[31m[nexus-v] Execution error: ${result.error.message}\x1b[0m`);
        }
        process.exit(1);
    }

    process.exit(result.status);
}

main();
