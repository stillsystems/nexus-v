import * as vscode from 'vscode';

export function activate(context: vscode.ExtensionContext) {
    console.log('Extension "{{ .Name }}" is now active with Webview!');

    const disposable = vscode.commands.registerCommand('{{ .CommandName }}', () => {
        const panel = vscode.window.createWebviewPanel(
            '{{ .Identifier }}.webview',
            '{{ .Name }}',
            vscode.ViewColumn.One,
            {
                enableScripts: true
            }
        );

        panel.webview.html = getWebviewContent('{{ .Name }}');
    });

    context.subscriptions.push(disposable);
}

function getWebviewContent(name: string) {
    return `<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>${name}</title>
    <style>
        body { font-family: sans-serif; padding: 20px; }
        h1 { color: #007acc; }
    </style>
</head>
<body>
    <h1>Hello from ${name}!</h1>
    <p>This is a VS Code Webview panel.</p>
</body>
</html>`;
}

export function deactivate() {}
